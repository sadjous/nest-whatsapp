{
  "name": "microservice-example",
  "version": "0.0.1",
  "scripts": {
    "start": "node -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "start:dev": "nodemon --watch src --ext ts,json --exec 'node -r ts-node/register -r tsconfig-paths/register src/main.ts'",
    "demo": "node -r ts-node/register -r tsconfig-paths/register src/demo-client.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "nest-whatsapp": "file:../../",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "axios": ">=1.13.5",
    "path-to-regexp": "^8.4.0",
    "ajv": "^8.18.0",
    "diff": "^4.0.4",
    "picomatch": "^4.0.4",
