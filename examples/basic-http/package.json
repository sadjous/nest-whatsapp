{
  "name": "basic-http-example",
  "version": "0.0.1",
  "scripts": {
    "start": "node -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "start:dev": "nodemon --watch src --ext ts,json --exec 'node -r ts-node/register -r tsconfig-paths/register src/main.ts'",
    "start:debug": "nodemon --watch src --ext ts,json --exec 'node --inspect=0.0.0.0:9229 -r ts-node/register -r tsconfig-paths/register src/main.ts'"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/terminus": "^11.0.0",
    "body-parser": "^2.2.2",
    "dotenv": "^17.3.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "nest-whatsapp": "file:../../",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.17",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "axios": ">=1.13.5",
    "path-to-regexp": "^8.4.0",
    "ajv": "^8.18.0",
    "diff": "^4.0.4",
    "picomatch": "^4.0.4",
    "brace-expansion": "^5.0.5",
    "minimatch": {
      "brace-expansion": "^2.0.3"
    },
    "micromatch": {
      "picomatch": "^2.3.2"
    }
  }
}
