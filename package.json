{
  "name": "nest-whatsapp",
  "version": "0.0.1",
  "schematics": "./schematics/whatsapp/collection.json",
  "description": "NestJS module for WhatsApp Cloud API (CJS/ESM)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build:lib": "tsup",
    "build:schematics": "tsc -p tsconfig.schematics.json",
    "build": "npm run build:lib && npm run build:schematics",
    "release": "semantic-release",
    "lint": "eslint 'src/**/*.ts' 'examples/**/*.ts' --fix",
    "format": "prettier --write '{src,examples}/**/*.{ts,js,json,md}'",
    "test": "jest",
    "test:ci": "jest --coverage --coverageThreshold '{\"global\":{\"branches\":90,\"functions\":90,\"lines\":90,\"statements\":90}}'",
    "prepare": "is-ci || npx simple-git-hooks",
    "docs": "typedoc",
    "examples:install": "npm --prefix examples/basic-http install && npm --prefix examples/microservice install",
    "example:basic:install": "npm --prefix examples/basic-http install",
    "example:micro:install": "npm --prefix examples/microservice install",
    "example:basic": "npm --prefix examples/basic-http run start",
    "example:micro": "npm --prefix examples/microservice run start",
    "typecheck:examples": "tsc --noEmit -p examples/basic-http/tsconfig.json && tsc --noEmit -p examples/microservice/tsconfig.json"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "type": "commonjs",
  "sideEffects": false,
  "typesVersions": {
    "*": {
      "metrics": [
        "./dist/metrics.d.ts"
      ],
      "health": [
        "./dist/health.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./metrics": {
      "import": {
        "types": "./dist/metrics.d.ts",
        "default": "./dist/metrics.mjs"
      },
      "require": {
        "types": "./dist/metrics.d.ts",
        "default": "./dist/metrics.js"
      }
    },
    "./health": {
      "import": {
        "types": "./dist/health.d.ts",
        "default": "./dist/health.mjs"
      },
      "require": {
        "types": "./dist/health.d.ts",
        "default": "./dist/health.js"
      }
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "reflect-metadata": "^0.2.2"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "npx --no -- commitlint --edit $1"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.3",
    "@angular-devkit/schematics": "^21.2.3",
    "@angular-devkit/schematics-cli": "^21.2.3",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11",
    "@nestjs/config": ">=3 <5",
    "@nestjs/core": "^11",
    "@nestjs/event-emitter": "^3",
    "@nestjs/microservices": "^11",
    "@nestjs/terminus": "^11",
    "@nestjs/testing": "^11",
    "@schematics/angular": "^21.2.3",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@swc/core": "^1.7.26",
    "@swc/jest": "^0.2.36",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "is-ci": "^3.0.1",
    "jest": "^30.2.0",
    "joi": "^18.1.2",
    "lint-staged": "^16.1.2",
    "prom-client": "^14.2.0",
    "prettier": "^3.8.1",
    "semantic-release": "^24.0.0",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@nestjs/axios": "^3 || ^4",
    "@nestjs/common": "^10 || ^11",
    "@nestjs/config": ">=3 <5",
    "@nestjs/core": "^10 || ^11",
    "@nestjs/event-emitter": "^2 || ^3",
    "@nestjs/microservices": "^10 || ^11",
    "@nestjs/terminus": "^11",
    "joi": "^18.1.2",
    "prom-client": "^14 || ^15"
  },
  "peerDependenciesMeta": {
    "@nestjs/terminus": {
      "optional": true
    },
    "@nestjs/microservices": {
      "optional": true
    },
    "@nestjs/config": {
      "optional": true
    },
    "@nestjs/event-emitter": {
      "optional": true
    },
    "joi": {
      "optional": true
    },
    "prom-client": {
      "optional": true
    }
  },
  "overrides": {
    "js-yaml": "^4.1.1",
    "handlebars": ">=4.7.9",
    "flatted": ">=3.4.2",
    "path-to-regexp": "^8.4.0",
    "diff": "^4.0.4",
    "picomatch": "^4.0.4",
    "brace-expansion": "^5.0.5",
    "minimatch": {
      "brace-expansion": "^2.0.3"
    },
    "micromatch": {
      "picomatch": "^2.3.2"
    },
    "test-exclude": {
      "minimatch": {
        "brace-expansion": "^1.1.13"
      }
    },
    "tinyglobby": {
      "picomatch": "^4.0.4"
    }
  },
  "files": [
    "dist/*.js",
    "dist/*.mjs",
    "dist/*.d.ts",
    "dist/*.d.mts",
    "schematics/dist/whatsapp/index.js",
    "schematics/whatsapp/collection.json",
    "schematics/whatsapp/schema.json",
    "schematics/whatsapp/files/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/softzenit/nest-whatsapp.git"
  },
  "bugs": {
    "url": "https://github.com/softzenit/nest-whatsapp/issues"
  },
  "homepage": "https://github.com/softzenit/nest-whatsapp#readme"
}
