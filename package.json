{
  "name": "@sadjous/nest-whatsapp",
  "version": "0.0.1",
  "schematics": "./schematics/whatsapp/collection.json",
  "description": "NestJS module for WhatsApp Cloud API (CJS/ESM)",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "scripts": {
    "build:cjs": "tsc --build tsconfig.cjs.json",
    "build:esm": "tsc --build tsconfig.esm.json",
    "build:schematics": "tsc -p tsconfig.schematics.json",
    "build": "npm run build:cjs && npm run build:esm && npm run build:schematics",
    "release": "semantic-release",
    "lint": "eslint 'src/**/*.ts' 'examples/**/*.ts' --fix",
    "format": "prettier --write '{src,examples}/**/*.{ts,js,json,md}'",
    "test": "jest",
    "test:ci": "jest --coverage --coverageThreshold '{\"global\":{\"branches\":90,\"functions\":90,\"lines\":90,\"statements\":90}}'",
    "prepare": "is-ci || npx simple-git-hooks",
    "docs": "typedoc",
    "examples:install": "npm --prefix examples/basic-http install && npm --prefix examples/microservice install",
    "example:basic:install": "npm --prefix examples/basic-http install",
    "example:micro:install": "npm --prefix examples/microservice install",
    "example:basic": "npm --prefix examples/basic-http run start",
    "example:micro": "npm --prefix examples/microservice run start",
    "typecheck:examples": "tsc --noEmit -p examples/basic-http/tsconfig.json && tsc --noEmit -p examples/microservice/tsconfig.json"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "type": "commonjs",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "joi": "^17.13.3",
    "prom-client": "^14.2.0",
    "reflect-metadata": "^0.2.2"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "npx --no -- commitlint --edit $1"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@angular-devkit/core": "^17.3.10",
    "@angular-devkit/schematics": "^17.3.10",
    "@angular-devkit/schematics-cli": "^20.3.10",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.15.0",
    "@nestjs/axios": "^3",
    "@nestjs/common": "^10",
    "@nestjs/config": ">=3 <5",
    "@nestjs/core": "^10",
    "@nestjs/event-emitter": "^2",
    "@nestjs/microservices": "^10",
    "@nestjs/terminus": "^10",
    "@nestjs/testing": "^10",
    "@schematics/angular": "^17.3.10",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/commit-analyzer": "^9.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^9.0.0",
    "@semantic-release/npm": "^12.0.2",
    "@swc/core": "^1.7.26",
    "@swc/jest": "^0.2.36",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.32.0",
    "globals": "^15.11.0",
    "is-ci": "^3.0.1",
    "jest": "^30.2.0",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "semantic-release": "^24.0.0",
    "simple-git-hooks": "^2.13.1",
    "typedoc": "^0.28.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@nestjs/axios": "^3",
    "@nestjs/common": "^10",
    "@nestjs/config": ">=3 <5",
    "@nestjs/core": "^10",
    "@nestjs/event-emitter": "^2",
    "@nestjs/microservices": "^10",
    "@nestjs/terminus": "^10"
  },
  "peerDependenciesMeta": {
    "@nestjs/terminus": {
      "optional": true
    },
    "@nestjs/microservices": {
      "optional": true
    },
    "@nestjs/config": {
      "optional": true
    },
    "@nestjs/event-emitter": {
      "optional": true
    }
  },
  "overrides": {
    "js-yaml": "^4.1.1"
  },
  "files": [
    "dist/**",
    "schematics/**",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sadjous/nest-whatsapp.git"
  },
  "bugs": {
    "url": "https://github.com/sadjous/nest-whatsapp/issues"
  },
  "homepage": "https://github.com/sadjous/nest-whatsapp#readme"
}
